root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{scala,sbt}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false  # Markdown 行尾雙空白有換行語意

[*.{yml,yaml}]
indent_style = space
indent_size = 2
